{
  "expo": {
    "name": "Gini",
    "slug": "gini-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "gini",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": { "policy": "appVersion" },
    "updates": {
      "url": "https://u.expo.dev/REPLACE_AFTER_EAS_INIT",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.lilaclabs.gini.mobile"
    },
    "android": {
      "package": "ai.lilaclabs.gini.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
